<view class="container">
  <!-- 添加任务模式 -->
  <block wx:if="{{mode === 'add' || mode === 'edit'}}">
    <view class="form-section">
      <view class="form-item">
        <text class="form-label">任务名称</text>
        <input
          class="form-input"
          placeholder="请输入任务名称"
          value="{{taskName}}"
          bindinput="onTaskNameInput"
          maxlength="30"
        />
      </view>

      <view class="form-item">
        <text class="form-label">打卡频率</text>
        <radio-group bindchange="onFrequencyChange">
          <label class="radio-label">
            <radio value="daily" checked="{{frequency === 'daily'}}" color="#4A90D9" />
            <text>每日</text>
          </label>
          <label class="radio-label">
            <radio value="workday" checked="{{frequency === 'workday'}}" color="#4A90D9" />
            <text>仅工作日</text>
          </label>
        </radio-group>
      </view>

      <view class="form-item">
        <text class="form-label">选择颜色</text>
        <view class="color-grid">
          <view
            class="color-item {{selectedColor === item ? 'selected' : ''}}"
            wx:for="{{presetColors}}"
            wx:key="*this"
            style="background-color: {{item}};"
            data-color="{{item}}"
            bindtap="onColorSelect"
          >
            <text class="color-check" wx:if="{{selectedColor === item}}">✓</text>
          </view>
        </view>
      </view>

      <view class="form-item">
        <text class="form-label">开始时间</text>
        <picker mode="date" value="{{startTime}}" bindchange="onStartTimeChange">
          <view class="picker">
            {{startTime ? startTime : '选择开始时间'}}
          </view>
        </picker>
      </view>

      <view class="form-item">
        <text class="form-label">结束时间</text>
        <picker mode="date" value="{{endTime}}" bindchange="onEndTimeChange">
          <view class="picker">
            {{endTime ? endTime : '选择结束时间'}}
          </view>
        </picker>
      </view>
    </view>
  </block>

  <!-- 标记未完成模式 -->
  <block wx:if="{{mode === 'miss'}}">
    <view class="form-section">
      <view class="task-display">
        <view class="task-display-name">{{taskNameDisplay}}</view>
        <view class="task-display-date">{{date}}</view>
      </view>

      <view class="status-display missed">
        <text class="status-icon">!</text>
        <text class="status-label">标记为未完成</text>
      </view>

      <view class="form-item">
        <text class="form-label">备注（可选）</text>
        <textarea
          class="form-textarea"
          placeholder="添加备注说明..."
          value="{{note}}"
          bindinput="onNoteInput"
          maxlength="200"
          auto-height
        />
      </view>
    </view>
  </block>

  <!-- 编辑备注模式 -->
  <block wx:if="{{mode === 'note'}}">
    <view class="form-section">
      <view class="task-display">
        <view class="task-display-name">{{taskNameDisplay}}</view>
        <view class="task-display-date">{{date}}</view>
      </view>

      <view class="form-item">
        <text class="form-label">状态</text>
        <radio-group bindchange="onStatusChange">
          <label class="radio-label" wx:for="{{statusOptions}}" wx:key="value">
            <radio value="{{item.value}}" checked="{{status === item.value}}" color="#4A90D9" />
            <text>{{item.label}}</text>
          </label>
        </radio-group>
      </view>

      <view class="form-item">
        <text class="form-label">备注（可选）</text>
        <textarea
          class="form-textarea"
          placeholder="添加备注说明..."
          value="{{note}}"
          bindinput="onNoteInput"
          maxlength="200"
          auto-height
        />
      </view>
    </view>
  </block>

  <!-- 保存按钮 -->
  <view class="save-section">
    <button class="save-btn" bindtap="handleSave">保存</button>
  </view>
</view>
