/* ==================== 页面容器 ==================== */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 60rpx;
}

/* ==================== 卡片通用 ==================== */
.card {
  background-color: #ffffff;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

/* ==================== 说明卡片 ==================== */
.info-card {
  border-left: 6rpx solid #4A90D9;
}

.code-block {
  background-color: #f8f9fa;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}

.code-text {
  font-size: 22rpx;
  color: #666666;
  font-family: monospace;
  word-break: break-all;
  line-height: 1.6;
}

.info-tips {
  display: flex;
  flex-direction: column;
}

.tip-item {
  font-size: 24rpx;
  color: #888888;
  line-height: 1.8;
}

/* ==================== 操作按钮卡片 ==================== */
.action-card {
  padding: 24rpx 32rpx;
}

.choose-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #4A90D9;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  text-align: center;
}

.choose-btn::after {
  border: none;
}

.import-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #43a047;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  text-align: center;
}

.import-btn::after {
  border: none;
}

.import-btn.disabled {
  background-color: #a5d6a7;
  color: rgba(255, 255, 255, 0.8);
}

/* ==================== 文件信息卡片 ==================== */
.file-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.file-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.file-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  background-color: #e3f2fd;
  color: #4A90D9;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.file-detail {
  display: flex;
  flex-direction: column;
}

.file-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 4rpx;
}

.file-count {
  font-size: 24rpx;
  color: #999999;
}

.clear-btn {
  padding: 12rpx 24rpx;
}

.clear-text {
  font-size: 26rpx;
  color: #e53935;
}

/* ==================== 预览卡片 ==================== */
.preview-list {
  display: flex;
  flex-direction: column;
}

.preview-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.preview-item:last-child {
  border-bottom: none;
}

.preview-date {
  font-size: 26rpx;
  color: #555555;
  font-family: monospace;
  width: 200rpx;
  flex-shrink: 0;
}

.preview-name {
  font-size: 26rpx;
  color: #333333;
  flex: 1;
  margin-right: 16rpx;
}

.preview-tag {
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.preview-tag text {
  font-size: 22rpx;
}

.tag-holiday {
  background-color: #fff3e0;
  color: #e65100;
}

.tag-workday {
  background-color: #e8f5e9;
  color: #2e7d32;
}

.preview-more {
  padding: 16rpx 0 0;
  text-align: center;
}

.more-text {
  font-size: 24rpx;
  color: #999999;
}

/* ==================== 提示信息 ==================== */
.msg-bar {
  display: flex;
  align-items: center;
  margin: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
}

.msg-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.msg-text {
  font-size: 26rpx;
  line-height: 1.5;
}

.error-bar {
  background-color: #fff0f0;
}

.error-bar .msg-icon {
  background-color: #e53935;
  color: #ffffff;
}

.error-bar .msg-text {
  color: #c62828;
}

.success-bar {
  background-color: #e8f5e9;
}

.success-bar .msg-icon {
  background-color: #43a047;
  color: #ffffff;
}

.success-bar .msg-text {
  color: #2e7d32;
}
